# ============================================================
# .gitignore – Wrkzg Solution
# ============================================================

# --- .NET Build-Artefakte ---
bin/
obj/
*.user
*.suo
.vs/
*.DotSettings.user

# --- Publish-Ausgaben ---
publish/
out/

# --- Sensitive Konfiguration ---
appsettings.Local.json
secrets.json
*.env
.env.*

# --- Verschlüsselte Token-Dateien (werden lokal generiert) ---
**/tokens/*.enc

# --- React / Node ---
node_modules/
src/Wrkzg.Frontend/dist/
src/Wrkzg.Frontend/.vite/

# --- wwwroot (wird vom Frontend-Build befüllt) ---
src/Wrkzg.Api/wwwroot/*
!src/Wrkzg.Api/wwwroot/.gitkeep

# --- SQLite Datenbank ---
*.db
*.db-shm
*.db-wal

# --- Betriebssystem ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
logs/
*.log

# --- Test-Ergebnisse ---
TestResults/
coverage/
*.coverage
*.coveragexml

# --- NuGet ---
*.nupkg
*.snupkg

# --- Temporäre Update-Dateien ---
WrkzgUpdate.zip


# --- IDE specific Files ---
.idea
.juni